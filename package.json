{
  "name": "loangenius-v2",
  "version": "0.1.0",
  "private": true,
  "description": "LoanGenius v2 CRM service for crm.smartr8.com/v2 with leads, portal apps, messaging, dialing, automations, and LOS workflows.",
  "engines": {
    "node": "22.x"
  },
  "type": "commonjs",
