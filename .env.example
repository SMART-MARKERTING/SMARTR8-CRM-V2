# Copy to .env and fill in. .env is gitignored — never commit real values.

# ── GoHighLevel ──────────────────────────────────────────────
GHL_LOCATION_ID=6eS74TvNAtT24FhvYn1t
GHL_API_VERSION=2021-04-15            # contacts/conversations endpoints
GHL_SEARCH_API_VERSION=2023-02-21     # contacts/search only
# Private Integration Token — ROTATE (was exposed in chat). Or use OAuth below.
GHL_PIT=replace-me

# ── GHL OAuth app (native conversation provider) ─────────────
GHL_CLIENT_ID=replace-me              # from Manage > Secrets > Client keys (has a -suffix)
GHL_CLIENT_SECRET=replace-me
GHL_REDIRECT_URI=https://your-app.example.com/oauth/callback
GHL_CONVERSATION_PROVIDER_ID=replace-me        # SMS-type provider (texts)
GHL_CALL_CONVERSATION_PROVIDER_ID=replace-me   # Type:Call provider (call logging); create a 2nd provider in GHL

# ── Telnyx (SMS) ─────────────────────────────────────────────
TELNYX_API_KEY=replace-me
TELNYX_FROM_NUMBER=+16197826916
TELNYX_MESSAGING_PROFILE_ID=40019e71-8d3d-47bc-9ac2-1f138e016dd1
# Extra sending numbers for the dialer selector + smart call routing (E.164,
# comma-separated). The primary FROM number is always included automatically.
TELNYX_NUMBERS=+16197826916,+14805551234

# ── BlueBubbles (iMessage) ───────────────────────────────────
# Prefer a NAMED Cloudflare tunnel URL (fixed). Quick-tunnel URLs rotate on restart.
BLUEBUBBLES_URL=https://your-named-tunnel.example.com
BLUEBUBBLES_PASSWORD=replace-me       # ROTATE (was exposed). Alphanumeric only.

# ── Routing ──────────────────────────────────────────────────
IMESSAGE_TAG=imessage
DEFAULT_COUNTRY_CODE=+1

# ── Telnyx Voice (calling) ───────────────────────────────────
TELNYX_VOICE_APP_ID=replace-me        # Voice API Application ID (connection_id)
# TELNYX_CONNECTION_ID is also accepted as an alias for TELNYX_VOICE_APP_ID.
TELNYX_AMD_MODE=greeting_end          # voicemail drop: wait for greeting/beep before playback
MY_CELL_NUMBER=+16232808351           # bridge/forward target (E.164)
CALL_NOW_TAG=call-now                 # tag a GHL contact with this → service dials it
CALL_POLL_MS=20000                    # how often (ms) to poll GHL for the call-now tag

# ── Browser softphone (Telnyx WebRTC) ────────────────────────
TELNYX_SIP_CONNECTION_ID=replace-me   # Telnyx SIP Connection (Credentials type) for the softphone
APP_PASSCODE=replace-me               # required to open/use the softphone — set a strong value

# ── GHL custom workflow action ───────────────────────────────
GHL_ACTION_SECRET=replace-me          # secret you append to the action URL (?key=…) so only GHL can trigger /ghl/workflow/*

# ── Inbound call routing ─────────────────────────────────────
INBOUND_MODE=app-then-cell            # "app-then-cell" (ring CRM, then cell) or "ivr" (press 1 to forward)
INBOUND_APP_RING_SECS=15              # how long to ring the CRM portal before forwarding to the cell
INBOUND_CELL_RING_SECS=25             # how long to ring the cell before giving up
# Business-hours forwarding window: in-hours an unanswered CRM ring forwards to the cell; out-of-hours
# calls go straight to the cell. A dialer toggle can disable forwarding entirely (CRM-only).
FORWARD_TZ=America/Phoenix            # IANA tz for the window (Arizona = no DST)
FORWARD_HOURS_START=9                 # whole hour, inclusive
FORWARD_HOURS_END=17                  # whole hour, exclusive (17 = 5 PM)
FORWARD_DAYS=1,2,3,4,5                # 1=Mon … 7=Sun (default Mon–Fri)

# ── Calling compliance guardrails ────────────────────────────
CALL_CONSENT_TAG=call_consent         # GHL tag required for AUTOMATED calls
CALL_HOURS_START=8                    # local calling window start (24h)
CALL_HOURS_END=21                     # local calling window end (9pm)
CALL_THROTTLE_MS=60000                # delay (ms) between automated calls
# DNC list persists at ${TOKEN_DIR}/dnc.json (no env needed)

# ── CRM (self-contained lead management) ─────────────────────
# Leads/notes/activity/automations live in SQLite on the same disk as TOKEN_DIR.
CRM_DB_FILE=crm.db                    # filename under TOKEN_DIR
LEAD_WEBHOOK_SECRET=replace-me        # ?key=… on POST /webhooks/lead (point your website form here)
AUTOMATION_POLL_MS=15000              # how often the automation worker runs due steps
CRM_DEFAULT_TIMEZONE=                 # e.g. America/Phoenix — enforces calling hours for voicemail when a lead has no tz
CRM_MIRROR_TO_GHL=false               # also mirror outbound texts into GHL (needs ghl_contact_id on the lead)
# Receives one-way live snapshots from the current crm.smartr8.com app.
# Prefer a dedicated long random secret; when blank, the app falls back to LEAD_WEBHOOK_SECRET.
CRM_V2_SYNC_SECRET=replace-me

# Portal / Apps encrypted borrower financial data. Required before full SSN, DOB,
# income, assets, or other application-sensitive fields can be saved.
# Generate a long random secret and store it only in the host's secret manager.
BORROWER_DATA_KEY=replace-with-long-random-secret
BORROWER_DATA_RETENTION_DAYS=2555

# ── Email (Resend) — new-lead automation email step ──────────
RESEND_API_KEY=replace-me
EMAIL_FROM=MDESHAZO@mykoal.com        # verified Resend sender
EMAIL_FROM_ALIASES=MDESHAZO@mykoal.com,info@mykoal.com   # optional comma-separated verified From choices
EMAIL_REPLY_TO=MDESHAZO@mykoal.com    # optional reply-to
RESEND_WEBHOOK_SECRET=replace-me      # Resend inbound webhook signing secret

# ── Voicemail drop (Telnyx AMD) ──────────────────────────────
# Public URL to a pre-recorded voicemail (mp3/wav). Optional when you upload
# the default recording in Settings > Voicemail AI.
VOICEMAIL_AUDIO_URL=https://your-host.example.com/voicemail.mp3
# ElevenLabs generated voicemail audio (also configurable in Settings > Voicemail AI).
ELEVENLABS_API_KEY=replace-me
ELEVENLABS_VOICE_ID=replace-me
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
ELEVENLABS_OUTPUT_FORMAT=mp3_44100_128

# ── Meta Conversions API (server-side ad-conversion events) ──
# Fires a "Lead" event to Meta when a new website lead lands (POST /webhooks/lead), matched
# by hashed email/phone so Meta optimizes ad delivery toward people who become leads. Same
# dataset as the browser pixel on the funnel, so events de-dup via event_id. Leave the token
# blank to disable (lead intake works either way).
META_PIXEL_ID=723066527555884        # Pixel / Dataset ID (also the funnel + console pixel)
META_CAPI_TOKEN=replace-me           # Events Manager → Settings → Generate access token
META_GRAPH_VERSION=v21.0             # any recent Graph API version; bump as Meta releases
META_ACTION_SOURCE=website           # website (funnel-origin) | system_generated (backend-only)
META_EVENT_SOURCE_URL=https://smartr8.com   # fallback capture-page URL when the funnel omits it
# META_TEST_EVENT_CODE=TEST12345     # Events Manager → Test Events; set to verify, then remove

# ── App server ───────────────────────────────────────────────
PORT=3000
TOKEN_DIR=.tokens                     # on Render set to the mounted disk, e.g. /data
